# =============================================================================
# nostrbtc Directory — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables with placeholder values MUST be changed before running.

# --- Relay Identity ---

# Your relay's domain name (used in NIP-05, NIP-11, relay URLs)
RELAY_DOMAIN=your-relay.example.com

# Relay operator's public key (hex, 64 chars)
# Used for NIP-11 relay info and admin access
RELAY_PUBKEY=<your-relay-pubkey-hex>

# Relay operator contact (NIP-05 address or email)
RELAY_CONTACT=operator@your-relay.example.com

# --- Relay Private Key ---
# Used to sign directory events (kind 30382, kind 9998/9999)
# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
RELAY_PRIVATE_KEY=<your-relay-private-key-hex>

# --- Bot Public Keys (optional, for NIP-05 system mappings) ---

# Dobby monitoring bot pubkey (hex)
DOBBY_PUBKEY=
# Relay bot pubkey (hex)
RELAY_BOT_PUBKEY=
# Email bridge bot pubkey (hex)
BRIDGE_PUBKEY=

# --- Database ---

# PostgreSQL connection string
DATABASE_URL=postgresql://directory:changeme@localhost:5432/directory

# PostgreSQL password (used by container orchestration)
POSTGRES_PASSWORD=changeme

# --- Redis ---

# Redis connection URL
REDIS_URL=redis://:changeme@localhost:6379/0

# Redis password
REDIS_PASSWORD=changeme

# --- Neo4j (social graph database) ---

# Neo4j connection URL
NEO4J_URL=neo4j://localhost:7687

# Neo4j credentials
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme

# --- GrapeRank ---

# Shared HMAC secret for signing Redis queue messages between
# the backend and Java GrapeRank worker. Must match on both sides.
# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
GRAPERANK_QUEUE_SECRET=<generate-a-random-64-char-hex-string>

# --- Authentication ---

# Secret used for HMAC signing of auth tokens and API keys.
# Generate with: python3 -c "import os; print(os.urandom(32).hex())"
AUTH_SECRET=<generate-a-random-64-char-hex-string>

# --- Optional ---

# VAPID keys for web push notifications (generate with pywebpush)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Tor hidden service .onion address (if running Tor)
TOR_ONION_ADDRESS=

# Owner pubkeys (comma-separated hex, for admin access)
OWNER_PUBKEYS=<your-relay-pubkey-hex>

# Bot pubkeys (comma-separated hex, bypasses rate limits)
BOT_PUBKEYS=
